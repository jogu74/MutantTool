generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  PLAYER
  ADMIN
}

enum SkillType {
  NATURAL
  TRAINED
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  name          String
  passwordHash  String
  role          UserRole       @default(PLAYER)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  character     Character?
  journalEntries JournalEntry[]
  backups       BackupSnapshot[] @relation("BackupCreatedBy")
}

model Campaign {
  id              String           @id @default(cuid())
  name            String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  characters      Character[]
  journalEntries  JournalEntry[]
  backupSnapshots BackupSnapshot[]
}

model Character {
  id                    String           @id @default(cuid())
  campaignId            String
  userId                String           @unique
  name                  String
  playerName            String
  className             String?
  formerOccupation      String?
  home                  String?
  age                   String?
  gender                String?
  length                String?
  weight                String?
  appearance            String?
  reputation            String?
  status                String?
  bodyPoints            Int              @default(0)
  traumaThreshold       Int              @default(0)
  traumaThresholdManual Int?
  notes                 String?
  kroncreditsOnHand     Int              @default(0)
  kroncreditsStash      Int              @default(0)
  creditsOnHand         Int              @default(0)
  creditsStash          Int              @default(0)
  jacksOnHand           Int              @default(0)
  jacksStash            Int              @default(0)
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  campaign              Campaign         @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  user                  User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  stats                 CharacterStats?
  skills                Skill[]
  weapons               Weapon[]
  equipmentItems        EquipmentItem[]
  armorItems            ArmorItem[]
  journalEntries        JournalEntry[]
}

model CharacterStats {
  characterId       String  @id
  strength          Int     @default(0)
  physique          Int     @default(0)
  size              Int     @default(0)
  agility           Int     @default(0)
  intelligence      Int     @default(0)
  willpower         Int     @default(0)
  personality       Int     @default(0)
  damageBonus       Int     @default(0)
  initiativeBonus   Int     @default(0)
  carryingCapacity  Int     @default(0)
  reactionValue     Int     @default(0)
  character         Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
}

model Skill {
  id         String    @id @default(cuid())
  characterId String
  name       String
  type       SkillType
  skillValue Int       @default(0)
  modifier   Int       @default(0)
  finalValue Int       @default(0)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  character  Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
}

model Weapon {
  id           String    @id @default(cuid())
  characterId  String
  name         String
  hitChance    Int       @default(0)
  initiative   Int       @default(0)
  damage       String?
  penetration  Int       @default(0)
  range        String?
  rateOfFire   String?
  minStrength  Int       @default(0)
  ammoCurrent  Int       @default(0)
  ammoMax      Int       @default(0)
  weight       Decimal   @default(0) @db.Decimal(10, 2)
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  character    Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
}

model EquipmentItem {
  id          String    @id @default(cuid())
  characterId String
  name        String
  weight      Decimal   @default(0) @db.Decimal(10, 2)
  quantity    Int       @default(1)
  notes       String?
  equipped    Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
}

model ArmorItem {
  id          String    @id @default(cuid())
  characterId String
  name        String
  armorValue  Int       @default(0)
  protection  String?
  weight      Decimal   @default(0) @db.Decimal(10, 2)
  location    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
}

model JournalEntry {
  id          String    @id @default(cuid())
  campaignId  String
  characterId String?
  authorId    String
  title       String?
  content     String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  campaign    Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  character   Character? @relation(fields: [characterId], references: [id], onDelete: SetNull)
  author      User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
}

model BackupSnapshot {
  id          String   @id @default(cuid())
  campaignId  String
  data        Json
  createdAt   DateTime @default(now())
  createdById String
  campaign    Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  createdBy   User     @relation("BackupCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
}
